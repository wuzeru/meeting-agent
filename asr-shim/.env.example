HOST=127.0.0.1
PORT=8787

# Optional: if set, clients must send Authorization: Bearer <PROXY_API_KEY>
PROXY_API_KEY=

VOLC_APP_KEY=
VOLC_ACCESS_KEY=
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
VOLC_MODEL_NAME=bigmodel

# Streaming behavior
SEGMENT_DURATION_MS=200
SEND_INTERVAL_MS=0
BODY_READ_TIMEOUT_MS=30000
REQUEST_TIMEOUT_MS=90000
SHUTDOWN_TIMEOUT_MS=8000
MAX_UPLOAD_BYTES=26214400

# Request tuning
ENABLE_ITN=true
ENABLE_PUNC=true
ENABLE_DDC=false
SHOW_UTTERANCES=false
RESULT_TYPE=full
